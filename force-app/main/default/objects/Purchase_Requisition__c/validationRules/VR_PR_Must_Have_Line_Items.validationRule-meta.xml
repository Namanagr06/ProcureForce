<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_PR_Must_Have_Line_Items</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
 ISPICKVAL( Status__c, &quot;Submitted&quot;),
 Line_Item_Count__c = 0 
)</errorConditionFormula>
    <errorMessage>A Purchase Requisition must contain at least one line item before it can be submitted.</errorMessage>
</ValidationRule>
